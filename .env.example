# BuildSpace SDK keys — get these from your BuildSpace dashboard
# Server-side secret key (never expose to the browser)
BUILDSPACE_SECRET_KEY=bs_sec_your_secret_key_here

# Browser-safe publishable key
NEXT_PUBLIC_BUILDSPACE_PUBLISHABLE_KEY=bs_pub_your_publishable_key_here

# libSQL/Turso connection URL. Defaults to file:local.db locally when blank.
BUILDSPACE_DB_URL=

# libSQL auth token. Leave blank for local file DB development.
BUILDSPACE_DB_TOKEN=
